{
  "name": "mikata-monorepo",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "bench": "vitest bench --run --config bench/vitest.config.ts",
    "bench:ci": "vitest bench --run --config bench/vitest.config.ts --outputJson bench-current.json && node bench/check-regressions.mjs bench-baseline.json bench-current.json",
    "bench:compiler": "vitest bench --run --config bench/vitest.config.ts bench/compiler.bench.ts",
    "bench:compare": "vitest bench --run --config bench/vitest.config.ts --compare bench-baseline.json",
    "bench:form": "vitest bench --run --config bench/vitest.config.ts bench/form.bench.ts",
    "bench:i18n": "vitest bench --run --config bench/vitest.config.ts bench/i18n.bench.ts",
    "bench:icons": "vitest bench --run --config bench/vitest.config.ts bench/icons.bench.ts",
    "bench:kit": "vitest bench --run --config bench/vitest.config.ts bench/kit.bench.ts",
    "bench:reactivity": "vitest bench --run --config bench/vitest.config.ts bench/reactivity.bench.ts",
    "bench:record": "vitest bench --run --config bench/vitest.config.ts --outputJson bench-baseline.json",
    "bench:router": "vitest bench --run --config bench/vitest.config.ts bench/router.bench.ts",
    "bench:runtime": "vitest bench --run --config bench/vitest.config.ts bench/runtime.bench.ts",
    "bench:server": "vitest bench --run --config bench/vitest.config.ts bench/server.bench.ts",
    "bench:store": "vitest bench --run --config bench/vitest.config.ts bench/store.bench.ts",
    "bench:ui": "vitest bench --run --config bench/vitest.config.ts bench/ui.bench.ts",
    "lint": "pnpm --filter @mikata/eslint-plugin build && eslint .",
    "test": "vitest",
    "test:run": "vitest run && pnpm --filter @mikata/docs test",
    "test:docs": "pnpm --filter @mikata/docs test",
    "dev": "pnpm --filter playground dev",
    "dev:ssr": "tsx integration/src/ssr-smoke.ts",
    "dev:kit": "pnpm --filter @mikata/example-kit-ssr dev"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "eslint": "9.39.4",
    "jsdom": "^29.0.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "8.0.0",
    "vitest": "^3.1.0"
  }
}
