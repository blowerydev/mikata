{
  "name": "@mikata/compiler",
  "version": "0.1.0",
  "description": "Vite/Babel plugin that compiles Mikata JSX to direct DOM operations",
  "keywords": [
    "mikata",
    "reactive",
    "signals",
    "compiler",
    "vite",
    "babel",
    "jsx"
  ],
  "author": "Brandon Lowery",
  "homepage": "https://github.com/blowerydev/mikata#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blowerydev/mikata.git",
    "directory": "packages/compiler"
  },
  "bugs": {
    "url": "https://github.com/blowerydev/mikata/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-syntax-jsx": "^7.25.0",
    "@babel/plugin-syntax-typescript": "^7.25.0"
  },
  "peerDependencies": {
    "vite": "^6.0.0"
  }
}
