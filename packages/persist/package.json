{
  "name": "@mikata/persist",
  "version": "0.1.0",
  "description": "Storage-backed signals with cross-tab sync for Mikata",
  "keywords": [
    "mikata",
    "reactive",
    "signals",
    "persist",
    "localstorage",
    "sessionstorage",
    "indexeddb",
    "broadcastchannel"
  ],
  "author": "Brandon Lowery",
  "homepage": "https://github.com/blowerydev/mikata#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blowerydev/mikata.git",
    "directory": "packages/persist"
  },
  "bugs": {
    "url": "https://github.com/blowerydev/mikata/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@mikata/reactivity": "workspace:*"
  }
}
