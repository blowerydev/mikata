{
  "name": "@mikata/ui",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./css": "./dist/index.css"
  },
  "sideEffects": ["*.css"],
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mikata/icons": "workspace:*",
    "@mikata/reactivity": "workspace:*",
    "@mikata/runtime": "workspace:*"
  },
  "peerDependencies": {
    "@mikata/i18n": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@mikata/i18n": {
      "optional": true
    }
  }
}
