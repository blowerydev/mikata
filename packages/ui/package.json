{
  "name": "@mikata/ui",
  "version": "0.1.0",
  "description": "Component library for Mikata - 80+ accessible, themeable components",
  "keywords": [
    "mikata",
    "reactive",
    "signals",
    "ui",
    "components",
    "design-system"
  ],
  "author": "Brandon Lowery",
  "homepage": "https://github.com/blowerydev/mikata#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blowerydev/mikata.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/blowerydev/mikata/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./css": "./dist/index.css"
  },
  "sideEffects": [
    "*.css",
    "./src/theme/registrations.ts",
    "./src/theme/index.ts"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mikata/reactivity": "workspace:*",
    "@mikata/runtime": "workspace:*"
  },
  "peerDependencies": {
    "@mikata/i18n": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@mikata/i18n": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mikata/server": "workspace:*"
  }
}
